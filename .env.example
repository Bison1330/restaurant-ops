# RestaurantOps Environment Variables
# Copy this file to .env and fill in your values

# ── Flask ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key-32-chars
FLASK_ENV=production

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/restaurantops

# ── Toast POS API ─────────────────────────────────────────────────────
TOAST_CLIENT_ID=your-toast-client-id
TOAST_CLIENT_SECRET=your-toast-client-secret
TOAST_LOCATION_ID=your-toast-location-guid

# ── xtraCHEF / Toast API ──────────────────────────────────────────────
XTRACHEF_API_KEY=your-xtrachef-api-key
XTRACHEF_LOCATION_ID=your-xtrachef-location-id

# ── Gordon Food Service SFTP ──────────────────────────────────────────
GFS_SFTP_HOST=sftp.gfs.com
GFS_SFTP_USER=your-gfs-username
GFS_SFTP_PASS=your-gfs-password
GFS_SFTP_PATH=/invoices

# ── FinTech Hospitality API ───────────────────────────────────────────
FINTECH_API_KEY=your-fintech-api-key
FINTECH_CUSTOMER_ID=your-fintech-customer-id

# ── OpenAI (for OCR enhancement) ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Invoice Email Ingestion ───────────────────────────────────────────
INVOICE_EMAIL=invoices@yourdomain.com
INVOICE_EMAIL_PASS=your-app-password
INVOICE_IMAP_SERVER=imap.gmail.com

# ── Upload Settings ───────────────────────────────────────────────────
UPLOAD_FOLDER=/opt/restaurant-ops/uploads
MAX_CONTENT_LENGTH=16777216

# ── Scheduler ─────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
EMAIL_POLL_INTERVAL_MINUTES=15
